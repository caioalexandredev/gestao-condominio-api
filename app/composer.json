{
    "name": "slim/app",
    "description": "Gestor de Condominios - API",
    "require": {
        "php": "^8.1",
        "slim/slim": "^4.0",
        "doctrine/orm": "^3.0",
        "php-di/php-di": "^6.0",
        "doctrine/doctrine-bundle": "^2.13",
        "slim/psr7": "^1.5",
        "symfony/dotenv": "^5.0",
        "vlucas/phpdotenv": "^5.5",
        "doctrine/annotations": "^2.0",
        "monolog/monolog": "^3.8",
        "odan/session": "^6.1",
        "php-di/slim-bridge": "^3.4",
        "zircote/swagger-php": "^5.0",
        "firebase/php-jwt": "^6.11",
        "doctrine/lexer": "^3.0",
        "doctrine/migrations": "^3.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ]
    }
}
